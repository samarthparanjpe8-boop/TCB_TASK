MONGODB_URI=mongodb://127.0.0.1:27017/classroom
PORT=4000
CORS_ORIGIN=http://localhost:5173

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-api-settings
# Required for /api/v1/auth/* (sign-in, register) — same anon key as the frontend
SUPABASE_ANON_KEY=your-anon-key
# TEACHER_EMAIL=teacher@yourdomain.com
# TEACHER_PASSWORD=your-password

# Comma-separated; these users become teachers on first authenticated request
TEACHER_EMAILS=you@example.com
